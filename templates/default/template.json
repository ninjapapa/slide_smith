{
  "template_id": "default",
  "name": "Default MVP Template",
  "version": "0.1",
  "deck": {
    "aspect_ratio": "16:9",
    "supported_layout_ids": [
      "title",
      "section",
      "title_and_bullets",
      "title_subtitle_and_bullets",
      "text_with_image"
    ]
  },
  "styles": {
    "title": {"font": "Calibri", "size_pt": 40, "color_hex": "111111", "bold": true, "align": "left"},
    "subtitle": {"font": "Calibri", "size_pt": 24, "color_hex": "333333", "italic": false, "align": "left"},
    "body": {"font": "Calibri", "size_pt": 18, "color_hex": "222222", "line_spacing_pt": 22},
    "bullets": {"font": "Calibri", "size_pt": 18, "color_hex": "222222", "line_spacing_pt": 22}
  },
  "native": {
    "layouts": []
  },
  "layouts": [
    {
      "id": "title",
      "layout": "Title Slide",
      "description": "Opening slide with title and subtitle.",
      "slots": [
        { "name": "title", "type": "text", "required": true, "placeholder_idx": 0 },
        { "name": "subtitle", "type": "text", "required": false, "placeholder_idx": 1 }
      ]
    },
    {
      "id": "section",
      "layout": "Section Header",
      "description": "Section divider slide.",
      "slots": [
        { "name": "title", "type": "text", "required": true, "placeholder_idx": 0 },
        { "name": "subtitle", "type": "text", "required": false, "placeholder_idx": 1 }
      ]
    },
    {
      "id": "title_and_bullets",
      "layout": "Title and Content",
      "description": "Title with bullet list content.",
      "slots": [
        { "name": "title", "type": "text", "required": true, "placeholder_idx": 0 },
        { "name": "bullets", "type": "bullet_list", "required": true, "placeholder_idx": 1, "max_items": 6, "notes": "Prefer concise bullets." }
      ]
    },
    {
      "id": "title_subtitle_and_bullets",
      "layout": "Title and Content",
      "description": "Title, subtitle, and bullet list content using the default template placeholders.",
      "slots": [
        { "name": "title", "type": "text", "required": true, "placeholder_idx": 0 },
        { "name": "subtitle", "type": "text", "required": true, "box": { "x": 0.8, "y": 1.7, "w": 8.0, "h": 0.5 }, "notes": "Synthetic subtitle area for default template compatibility." },
        { "name": "bullets", "type": "bullet_list", "required": true, "placeholder_idx": 1, "max_items": 6, "notes": "Prefer concise bullets." }
      ]
    },
    {
      "id": "text_with_image",
      "layout": "Two Content",
      "description": "Preferred semantic image+text layout for the default template.",
      "slots": [
        { "name": "title", "type": "text", "required": true, "placeholder_idx": 0 },
        { "name": "image", "type": "image", "required": true, "placeholder_idx": 1, "aspect_ratio": "flexible" },
        { "name": "body", "type": "text", "required": true, "placeholder_idx": 2, "notes": "Keep body concise." }
      ]
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/slide-smith/deck-spec.schema.json",
  "title": "slide_smith deck spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["slides"],
  "properties": {
    "title": {"type": "string"},
    "subtitle": {"type": "string"},
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/slide"}
    }
  },
  "$defs": {
    "image": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "alt": {"type": "string"}
          }
        }
      ]
    },
    "agenda_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body"],
      "properties": {
        "marker": {"type": "string"},
        "body": {"type": "string", "minLength": 1}
      }
    },
    "three_col_icon_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "icon"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "body": {"type": "string", "minLength": 1},
        "caption": {"type": "string"},
        "icon": {"$ref": "#/$defs/image"}
      }
    },
    "compare_side": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {"$ref": "#/$defs/image"},
        "title": {"type": "string"},
        "body": {"type": "string"}
      }
    },
    "base_slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout_id", "title"],
      "properties": {
        "layout_id": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "subtitle": {"type": "string"},
        "body": {"type": "string"},
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "image": {"$ref": "#/$defs/image"},
        "notes": {"type": "string"},
        "table_text": {"type": "string", "minLength": 1},
        "col1_body": {"type": "string", "minLength": 1},
        "col2_body": {"type": "string", "minLength": 1},
        "items": {"type": "array"},
        "left": {"$ref": "#/$defs/compare_side"},
        "right": {"$ref": "#/$defs/compare_side"}
      }
    },
    "title_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {"properties": {"layout_id": {"const": "title"}}, "required": ["layout_id", "title"]}
      ]
    },
    "section_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {"properties": {"layout_id": {"const": "section"}}, "required": ["layout_id", "title"]}
      ]
    },
    "title_and_bullets_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {"layout_id": {"const": "title_and_bullets"}},
          "required": ["layout_id", "title"],
          "anyOf": [{"required": ["bullets"]}, {"required": ["body"]}]
        }
      ]
    },
    "title_subtitle_and_bullets_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {"layout_id": {"const": "title_subtitle_and_bullets"}},
          "required": ["layout_id", "title", "subtitle"],
          "anyOf": [{"required": ["bullets"]}, {"required": ["body"]}]
        }
      ]
    },
    "text_with_image_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {"layout_id": {"const": "text_with_image"}},
          "required": ["layout_id", "title", "image"],
          "anyOf": [{"required": ["body"]}, {"required": ["bullets"]}]
        }
      ]
    },
    "version_page_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {"properties": {"layout_id": {"const": "version_page"}}, "required": ["layout_id", "title", "table_text"]}
      ]
    },
    "agenda_with_image_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {
            "layout_id": {"const": "agenda_with_image"},
            "items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/agenda_item"}}
          },
          "required": ["layout_id", "title", "image", "items"]
        }
      ]
    },
    "two_col_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {"properties": {"layout_id": {"const": "two_col"}}, "required": ["layout_id", "title", "col1_body", "col2_body"]}
      ]
    },
    "three_col_with_icons_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {
            "layout_id": {"const": "three_col_with_icons"},
            "items": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {"$ref": "#/$defs/three_col_icon_item"}
            }
          },
          "required": ["layout_id", "title", "items"]
        }
      ]
    },
    "picture_compare_slide": {
      "allOf": [
        {"$ref": "#/$defs/base_slide"},
        {
          "properties": {"layout_id": {"const": "picture_compare"}},
          "required": ["layout_id", "title", "left", "right"]
        }
      ]
    },
    "slide": {
      "oneOf": [
        {"$ref": "#/$defs/title_slide"},
        {"$ref": "#/$defs/section_slide"},
        {"$ref": "#/$defs/title_and_bullets_slide"},
        {"$ref": "#/$defs/title_subtitle_and_bullets_slide"},
        {"$ref": "#/$defs/text_with_image_slide"},
        {"$ref": "#/$defs/version_page_slide"},
        {"$ref": "#/$defs/agenda_with_image_slide"},
        {"$ref": "#/$defs/two_col_slide"},
        {"$ref": "#/$defs/three_col_with_icons_slide"},
        {"$ref": "#/$defs/picture_compare_slide"}
      ]
    }
  }
}

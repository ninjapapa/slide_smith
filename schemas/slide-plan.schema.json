{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ninjapapa/slide_smith/schemas/slide-plan.schema.json",
  "title": "slide_smith SlidePlan (v1.2 draft)",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "slides"],
  "properties": {
    "version": {"type": "string"},
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string"}
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["intent", "fields"],
        "properties": {
          "intent": {
            "type": "string",
            "enum": ["title", "section", "bullets", "two_column", "image"]
          },
          "fields": {"type": "object"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}

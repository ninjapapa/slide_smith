        {
          "$ref": "#/$defs/two_col_with_subtitle_slide"
        },
        {
          "$ref": "#/$defs/three_col_with_subtitle_slide"
        },
        {
          "$ref": "#/$defs/three_col_with_icons_slide"
        },
        {
          "$ref": "#/$defs/five_col_with_icons_slide"
